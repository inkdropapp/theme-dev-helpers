{
  "name": "@inkdropapp/theme-dev-helpers",
  "version": "0.5.2",
  "description": "A helper module for creating themes for Inkdrop",
  "keywords": [
    "inkdrop",
    "markdown"
  ],
  "license": "MIT",
  "author": "Takuya Matsuyama<t@inkdrop.app>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkdropapp/theme-dev-helpers.git"
  },
  "bin": {
    "dev-server": "./bin/dev-server",
    "generate-palette": "./bin/generate-palette"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "index.html",
    "vite.config.ts",
    "tsconfig.json"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@inkdropapp/base-ui-theme": "^0.7.5",
    "@inkdropapp/css": "^0.8.0",
    "@vitejs/plugin-react": "^6.0.2",
    "commander": "^15.0.0",
    "puppeteer": "^25.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
